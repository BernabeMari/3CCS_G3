@{
    var fullName = ViewBag.FullName;
    var idNumber = ViewBag.IdNumber;
    var course = ViewBag.Course;
    var sectionn = ViewBag.Section;
    var score = ViewBag.Score;
    var allStudents = ViewBag.AllStudents as List<Student>;
    var isProfileVisible = ViewBag.IsProfileVisible != null ? (bool)ViewBag.IsProfileVisible : false;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            height: 100vh;
            background: #fff6f1;
            display: flex;
        }

        .dashboard-container {
            display: flex;
            width: 100%;
        }

        /* Sidebar is fixed on the left */
        .sidebar {
            width: 210px;
            background: linear-gradient(180deg, #c3e8b6, #badbd2);
            padding: 25px 15px;
            display: flex;
            flex-direction: column;
            align-items: center;
            box-shadow: 5px 0 15px rgba(0, 0, 0, 0.1);
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            overflow-y: auto;
        }

        .logo {
            text-align: center;
            margin-bottom: 40px;
        }

            .logo img {
                width: 60px;
            }

            .logo h2 {
                font-size: 22px;
                font-weight: 700;
                margin: 10px 0 5px;
                color: #333;
            }

            .logo p {
                font-size: 14px;
                color: #555;
                font-weight: 500;
            }

        .sidebar-link {
            display: flex;
            align-items: center;
            text-decoration: none;
            color: #333;
            font-size: 16px;
            font-weight: 600;
            padding: 12px 20px;
            margin: 8px 0;
            border-radius: 12px;
            width: 100%;
            transition: all 0.3s ease;
        }

            .sidebar-link i {
                margin-right: 12px;
                font-size: 18px;
            }

            .sidebar-link.active {
                background: #fff6f1;
                font-weight: bold;
                color: #222;
                box-shadow: inset 3px 3px 8px rgba(0, 0, 0, 0.05);
            }

            .sidebar-link:hover {
                background: rgba(255, 255, 255, 0.5);
                transform: scale(1.02);
            }

        .content {
            flex-grow: 1;
            padding: 30px;
            width: 40%;
            height: 150vh;
            overflow-y: auto;
        }

        .switch {
            position: relative;
            display: inline-block;
            width: 50px;
            height: 25px;
        }

            .switch input {
                opacity: 0;
                width: 0;
                height: 0;
            }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #ccc;
            transition: .4s;
            border-radius: 25px;
        }

            .slider:before {
                position: absolute;
                content: "";
                height: 18px;
                width: 18px;
                left: 4px;
                bottom: 3px;
                background-color: white;
                transition: .4s;
                border-radius: 50%;
            }

        input:checked + .slider {
            background-color: #4CAF50;
        }

            input:checked + .slider:before {
                transform: translateX(24px);
            }

        .student-info {
            display: flex;
            flex-direction: column;
            align-items: center; /* Center horizontally */
            justify-content: center; /* Center vertically */
            text-align: center;
            width: 100%;
            height: 100vh; /* Full height */
            padding-left: 220px; /* Offset for the sidebar */
        }

        /* Profile Picture Area */
        .profile-pic-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            margin-top: 30px;
            padding: 20px;
            border: 2px dashed #ccc;
            width: 200px;
            height: 200px;
            border-radius: 10px;
            display: none; /* Initially hidden */
        }

            .profile-pic-container img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                border-radius: 10px;
            }

            .profile-pic-container p {
                font-size: 14px;
                color: #666;
            }

        /* Edit Button */
        .edit-button {
            padding: 10px 20px;
            font-size: 16px;
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            margin-top: 20px;
        }

            .edit-button:hover {
                background-color: #45a049;
            }

        /* Save Button */
        .save-button {
            padding: 10px 20px;
            font-size: 16px;
            background-color: #007bff;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            margin-top: 20px;
            display: none; /* Initially hidden */
        }

            .save-button:hover {
                background-color: #0056b3;
            }

        .resume-section {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-top: 40px;
            width: 100%;
        }

        .resume-upload-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            margin-top: 20px;
            padding: 20px;
            border: 2px dashed #ccc;
            width: 300px;
            height: 150px;
            border-radius: 10px;
            cursor: pointer;
        }

        .current-resume {
            margin: 20px 0;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 5px;
            width: 300px;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <aside class="sidebar">
            <div class="logo">
                <img src="~/images/student.png" alt="EduBadge Logo">
                <h2>EduBadge</h2>
                <p>Student Dashboard</p>
            </div>
            <nav>
                <a href="/Dashboard/StudentDashboard" class="sidebar-link">
                    <i class="fas fa-th-large"></i> Dashboard
                </a>
                <a href="#" class="sidebar-link active">
                    <i class="fas fa-user"></i> Profile
                </a>

                <a href="/Home/Login" class="sidebar-link">
                    <i class="fas fa-sign-out-alt"></i> Log Out
                </a>
            </nav>
        </aside>

        <div class="student-info">
            <h2>Profile Visibility</h2>
            <label class="switch">
                <input type="checkbox" id="togglePrivacy" onchange="togglePrivacySetting()" @(isProfileVisible ? "checked" : "")>
                <span class="slider round"></span>
            </label>
            <p id="privacyStatus">@(isProfileVisible ? "Your profile is visible to employers." : "Your profile is hidden.")</p>

            <!-- Edit Profile Picture Button -->
            <button class="edit-button" onclick="showDragDropArea()">Edit Profile Picture</button>


            <!-- Profile Picture Drag and Drop Area -->
            <div class="profile-pic-container" id="profilePicContainer" ondrop="drop(event)" ondragover="allowDrop(event)">
                <p>Drag and drop your profile picture here</p>
                <img id="profilePicPreview" src="" alt="Profile Picture" style="display: none;" />
            </div>

            <!-- Save Button -->
            <button class="save-button" id="saveProfilePic" onclick="saveProfilePic()">Save Profile Picture</button>
        </div>
    </div>
    <!-- Add this section after the profile picture section -->
    <div class="resume-section">
        <!-- Make sure this is in the resume section -->
        <h2>Resume</h2>
        <label class="switch">
            <input type="checkbox" id="toggleResumeVisibility" onchange="toggleResumeVisibility()" @(ViewBag.IsResumeVisible ? "checked" : "")>
            <span class="slider round"></span>
        </label>
        <p id="resumeVisibilityStatus">@(ViewBag.IsResumeVisible ? "Your resume is visible to others." : "Your resume is private.")</p>

        <!-- Current Resume Status -->
        <div class="current-resume" id="currentResumeSection" style="@(string.IsNullOrEmpty(ViewBag.ResumePath) ? "display: none;" : "")">
            <p>Current Resume: <a href="@ViewBag.ResumePath" target="_blank" id="currentResumeName">View Resume</a></p>
            <button class="edit-button" onclick="showResumeUploadArea()">Replace Resume</button>
        </div>

        <!-- Add Resume Button (shown when no resume exists) -->
        <button class="edit-button" id="addResumeButton" style="@(!string.IsNullOrEmpty(ViewBag.ResumePath) ? "display: none;" : "")" onclick="showResumeUploadArea()">Add Resume</button>

        <!-- Resume Upload Area -->
        <div class="resume-upload-container" id="resumeUploadContainer" style="display: none;">
            <p>Drag and drop your resume here or click to select a file</p>
            <input type="file" id="resumeFileInput" accept=".pdf,.doc,.docx" style="display: none;" onchange="handleResumeFileSelect(event)">
        </div>

        <!-- Save Button -->
        <button class="save-button" id="saveResume" style="display: none;" onclick="saveResume()">Save Resume</button>
    </div>

    <!-- Hidden input to store base64 resume file -->
    <input type="hidden" id="base64Resume" />
    <input type="hidden" id="resumeFileName" />
    <!-- Hidden input to store base64 image -->
    <input type="hidden" id="base64Image" />

</body>

<script>
    // Show drag-and-drop area when the edit button is clicked
    function showDragDropArea() {
        document.querySelector('.edit-button').style.display = 'none';  // Hide the edit button
        document.getElementById('profilePicContainer').style.display = 'flex';  // Show the drag-and-drop area
        document.getElementById('saveProfilePic').style.display = 'inline-block';  // Show the save button
    }

    // Allow dropping of the image file
    function allowDrop(event) {
        event.preventDefault();
    }

    // Handle the drop event
    function drop(event) {
        event.preventDefault();
        var file = event.dataTransfer.files[0];  // Get the first file

        // Check if the file is an image
        if (file && file.type.startsWith('image/')) {
            var reader = new FileReader();
            reader.onload = function(e) {
                // Set the base64 string to the hidden input
                var base64Image = e.target.result.split(',')[1];  // Remove 'data:image/*;base64,'

                // Set the hidden input value to the base64 image string
                document.getElementById('base64Image').value = base64Image;

                // Display the image preview
                document.getElementById('profilePicPreview').style.display = 'block';
                document.getElementById('profilePicPreview').src = e.target.result;
            }
            reader.readAsDataURL(file);
        }
    }

        // Example function for uploading profile picture
    function uploadProfilePicture(inputElement) {
        const file = inputElement.files[0];
        if (!file) return;

        // Check file size (max 1MB)
        if (file.size > 1024 * 1024) {
            alert("Image is too large. Maximum size is 1MB.");
            return;
        }

        const reader = new FileReader();
        reader.onload = function(e) {
            const base64Image = e.target.result; // This includes the data URL prefix

            // Send to server
            fetch('/Dashboard/SaveProfilePicture', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ base64Image: base64Image })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Immediately update the image on the page
                    document.getElementById('profileImage').src = base64Image;
                    alert(data.message);
                } else {
                    alert(data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error uploading image. Please try again.');
            });
        };
        reader.readAsDataURL(file); // Read as data URL which includes the prefix
    }

    // Save the profile picture
    function saveProfilePic() {
        var base64Image = document.getElementById('base64Image').value;

        if (!base64Image) {
            alert("No image selected.");
            return;
        }

        fetch('/Dashboard/SaveProfilePicture', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ Base64Image: base64Image })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert("Profile picture saved successfully!");
            } else {
                alert("Failed to save profile picture.");
            }
        })
        .catch(error => console.error("Error saving profile picture:", error));
    }

    // Resize the image before sending it
    function resizeImage(file, maxWidth, maxHeight, callback) {
        var img = new Image();
        var reader = new FileReader();
        reader.onload = function(e) {
            img.onload = function() {
                var canvas = document.createElement('canvas');
                var ctx = canvas.getContext('2d');

                // Calculate the new dimensions
                var ratio = Math.min(maxWidth / img.width, maxHeight / img.height);
                var width = img.width * ratio;
                var height = img.height * ratio;

                // Set the canvas size
                canvas.width = width;
                canvas.height = height;

                // Draw the image on the canvas
                ctx.drawImage(img, 0, 0, width, height);

                // Get the resized image as Base64
                callback(canvas.toDataURL(file.type));
            };
            img.src = e.target.result;
        };
        reader.readAsDataURL(file);
    }

    // Handle the file input change event (optional if you have an <input type="file">)
    function handleFileInput(event) {
        var file = event.target.files[0];
        if (file && file.type.startsWith('image/')) {
            resizeImage(file, 300, 300, function(base64Image) {
                // Display the image preview
                document.getElementById('profilePicPreview').style.display = 'block';
                document.getElementById('profilePicPreview').src = base64Image;
                // Store the base64 image string
                document.getElementById('base64Image').value = base64Image;
            });
        } else {
            alert('Please select a valid image file.');
        }
    }

    function togglePrivacySetting() {
        var isChecked = document.getElementById("togglePrivacy").checked;
        var statusText = isChecked ? "Your profile is visible to employers." : "Your profile is hidden.";
        document.getElementById("privacyStatus").innerText = statusText;

        fetch('/Dashboard/UpdatePrivacySetting', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ isVisible: isChecked })
        })
        .then(response => response.json())
        .then(data => {
            console.log("Privacy setting updated:", data);
        })
        .catch(error => console.error("Error updating privacy setting:", error));
    }

        // Show resume upload area
    function showResumeUploadArea() {
        document.getElementById('addResumeButton').style.display = 'none';
        document.getElementById('currentResumeSection').style.display = 'none';
        document.getElementById('resumeUploadContainer').style.display = 'flex';
        document.getElementById('saveResume').style.display = 'inline-block';

        // Make the container clickable to trigger file input
        document.getElementById('resumeUploadContainer').addEventListener('click', function() {
            document.getElementById('resumeFileInput').click();
        });
    }

    // Handle file selection through the file input
    function handleResumeFileSelect(event) {
        const file = event.target.files[0];
        if (file) {
            processResumeFile(file);
        }
    }

    // Handle drag and drop for resume
    document.getElementById('resumeUploadContainer').addEventListener('dragover', function(e) {
        e.preventDefault();
        e.stopPropagation();
        this.style.borderColor = '#4CAF50';
    });

    document.getElementById('resumeUploadContainer').addEventListener('dragleave', function(e) {
        e.preventDefault();
        e.stopPropagation();
        this.style.borderColor = '#ccc';
    });

    document.getElementById('resumeUploadContainer').addEventListener('drop', function(e) {
        e.preventDefault();
        e.stopPropagation();
        this.style.borderColor = '#ccc';

        const file = e.dataTransfer.files[0];
        if (file) {
            processResumeFile(file);
        }
    });

    // Process the selected resume file
    function processResumeFile(file) {
        // Check file type
        const acceptedTypes = ['.pdf', '.doc', '.docx'];
        const fileExtension = file.name.substring(file.name.lastIndexOf('.')).toLowerCase();

        if (!acceptedTypes.includes(fileExtension)) {
            alert('Please upload a PDF, DOC, or DOCX file.');
            return;
        }

        // Check file size (max 10MB)
        if (file.size > 10 * 1024 * 1024) {
            alert('File too large. Maximum size is 10MB.');
            return;
        }

        // Read file as base64
        const reader = new FileReader();
        reader.onload = function(e) {
            // Store base64 file and filename
            document.getElementById('base64Resume').value = e.target.result;
            document.getElementById('resumeFileName').value = file.name;

            // Update UI to show file selected
            document.getElementById('resumeUploadContainer').innerHTML = `
                <p>Selected file: ${file.name}</p>
                <p>(${(file.size / 1024).toFixed(2)} KB)</p>
            `;
        };
        reader.readAsDataURL(file);
    }

        function toggleResumeVisibility() {
        var isChecked = document.getElementById("toggleResumeVisibility").checked;
        var statusText = isChecked ? "Your resume is visible to others." : "Your resume is private.";
        document.getElementById("resumeVisibilityStatus").innerText = statusText;

        fetch('/Dashboard/UpdateResumeVisibility', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ isVisible: isChecked })
        })
        .then(response => response.json())
        .then(data => {
            console.log("Resume visibility updated:", data);
        })
        .catch(error => console.error("Error updating resume visibility:", error));
    }

    // Save resume
    function saveResume() {
        const base64Resume = document.getElementById('base64Resume').value;
        const resumeFileName = document.getElementById('resumeFileName').value;

        if (!base64Resume || !resumeFileName) {
            alert('No file selected.');
            return;
        }

        fetch('/Dashboard/SaveResume', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                ResumeFile: base64Resume,
                ResumeFileName: resumeFileName
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert('Resume uploaded successfully!');

                // Update UI
                document.getElementById('resumeUploadContainer').style.display = 'none';
                document.getElementById('saveResume').style.display = 'none';

                // Update current resume section
                document.getElementById('currentResumeSection').style.display = 'block';
                document.getElementById('currentResumeName').href = data.resumeUrl;

                // Hide add button, show current resume
                document.getElementById('addResumeButton').style.display = 'none';
                document.getElementById('currentResumeSection').style.display = 'block';
            } else {
                alert('Failed to upload resume: ' + data.message);
            }
        })
        .catch(error => {
            console.error('Error uploading resume:', error);
            alert('Error uploading resume. Please try again.');
        });
    }
</script>


</html>
