                // Create the alert
                const alertHtml = `
                    <div id="${messageId}" class="alert alert-${type} alert-dismissible fade show" role="alert" style="min-width: 250px; box-shadow: 0 4px 8px rgba(0,0,0,0.1);">
                        ${message}
