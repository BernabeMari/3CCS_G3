<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        @@font-face {
            font-family: 'Hagrid';
            src: url('/fonts/Hagrid-Regular-trial.ttf') format('truetype');
            font-weight: normal;
            font-style: normal;
        }

        body, h3, p, label, select, button {
            font-family: 'Hagrid', sans-serif;
        }

        input[type="text"], input[type="password"] {
            font-family: Arial, sans-serif;
        }

        body {
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background: linear-gradient(180deg, #c3e8b6, #badbd2);
        }

        .container {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 85%;
            max-width: 320px;
            background: linear-gradient(180deg, #c3e8b6, #badbd2);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.2);
            position: absolute;
            left: 8%;
            top: 50%;
            transform: translateY(-50%);
            padding: 15px;
        }

            .container::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                pointer-events: none;
                background: linear-gradient(to right, rgba(255, 255, 255, 0.5) 0%, transparent 15%, transparent 85%, rgba(255, 255, 255, 0.5) 100%), linear-gradient(to bottom, rgba(255, 255, 255, 0.5) 0%, transparent 15%, transparent 85%, rgba(255, 255, 255, 0.5) 100%);
            }

        .form-control {
            background: transparent;
            border: none;
            border-bottom: 1.5px solid #333;
            border-radius: 0;
            outline: none;
            box-shadow: none;
            color: #333;
            font-size: 14px;
            padding: 6px;
            width: 100%;
        }

            .form-control:focus {
                border-bottom: 1.5px solid #5E35B1;
            }

        .btn-primary {
            background: linear-gradient(180deg, #d9f2d1, #b3e0cc);
            border: none;
            padding: 8px 15px;
            width: 100%;
            font-weight: bold;
            font-size: 16px;
            color: black;
            text-shadow: 1px 1px 0px rgba(255, 255, 255, 0.6);
            border-radius: 12px;
            box-shadow: 0 3px 5px rgba(0, 0, 0, 0.2);
            transition: all 0.3s ease;
        }

            .btn-primary:hover {
                background: linear-gradient(180deg, #c3e8b6, #a3d5c2);
                box-shadow: 0 5px 8px rgba(0, 0, 0, 0.3);
            }
    </style>
</head>
<body>
    <div class="container">
        <div class="login-form">
            <h2 class="text-center my-4">Welcome Back!</h2>
            <h5 class="text-center my-4">Login to EduBadge</h5>

            @if (!string.IsNullOrEmpty(ViewBag.Error))
            {
                <div class="alert alert-danger text-center">
                    @ViewBag.Error
                </div>
            }

            <form method="post" action="/Account/Login">
                <div class="card-body">
                    <div class="form-group">
                        <label for="role"><b>Role</b></label>
                        <select id="role" name="role" class="form-control form-control-lg" required>
                            <option value="" disabled selected>Choose your role</option>
                            <option value="student">Student</option>
                            <option value="employer">Employer</option>
                            <option value="admin">Admin</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="username"><b>Username</b></label>
                        <input type="text" id="username" name="username" class="form-control form-control-lg" required placeholder="Enter your username" />
                    </div>

                    <div class="form-group">
                        <label for="password"><b>Password</b></label>
                        <input type="password" id="password" name="password" class="form-control form-control-lg" required placeholder="Enter your password" />
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-primary btn-lg mt-4">Login</button>
                    </div>
                    <div class="text-center mt-3">
                        <p>Don't have an account? <a href="/Home/Signup" class="text-decoration-none" style="color: #7E57C2;">Sign Up here</a></p>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
