@model Certificate[]
@{
    Layout = null;
    string studentId = ViewBag.StudentId ?? Context.Session.GetString("IdNumber");
    string fullName = ViewBag.FullName ?? "Student";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Programming Certificates</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
    
    <style>
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            height: 100vh;
            background: #fff6f1;
            display: flex;
            overflow: hidden;
        }

        .dashboard-container {
            display: flex;
            width: 100%;
            overflow: hidden;
        }

        /* Sidebar styles */
        .sidebar {
            width: 210px !important;
            background: linear-gradient(180deg, #8b0000, #c0392b);
            padding: 25px 15px;
            display: flex;
            flex-direction: column;
            align-items: center;
            box-shadow: 5px 0 15px rgba(0, 0, 0, 0.1);
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            overflow-y: auto;
            z-index: 100;
        }

        .logo {
            text-align: center;
            margin-bottom: 40px;
        }

        .logo img {
            width: 60px;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            background: white;
            padding: 5px;
        }

        .logo h2 {
            font-size: 22px;
            font-weight: 700;
            margin: 10px 0 5px;
            color: #fff;
        }

        .logo p {
            font-size: 14px;
            color: rgba(255, 255, 255, 0.8);
            font-weight: 500;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            text-decoration: none;
            color: #333;
            font-size: 16px;
            font-weight: 600;
            padding: 12px 20px;
            margin: 8px 0;
            border-radius: 12px;
            width: 100%;
            transition: all 0.3s ease;
        }

        .sidebar-link i {
            margin-right: 12px;
            font-size: 18px;
        }

        .sidebar-link.active {
            background: #fff6f1;
            font-weight: bold;
            color: #e74c3c;
            box-shadow: inset 3px 3px 8px rgba(0, 0, 0, 0.05);
        }

        .sidebar-link:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: scale(1.02);
            color: #fff;
        }

        .content {
            flex-grow: 1;
            padding: 25px;
            width: calc(100% - 240px);
            margin-left: 240px;
            max-height: 100vh;
            overflow-y: auto;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .content h1 {
            font-size: 28px;
            font-weight: 700;
            color: #c0392b;
            margin: 0;
        }

        .certificate-card {
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
            margin-bottom: 20px;
            transition: all 0.3s ease;
            border-top: 4px solid #e74c3c;
            overflow: hidden;
        }

        .certificate-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }

        .certificate-header {
            background-color: #f9f9f9;
            padding: 15px 20px;
            border-bottom: 1px solid #eee;
        }

        .certificate-title {
            font-size: 20px;
            font-weight: 700;
            color: #333;
            margin: 0;
            display: flex;
            align-items: center;
        }
        
        .certificate-title i {
            margin-right: 10px;
            color: #e74c3c;
        }

        .certificate-body {
            padding: 20px;
        }

        .certificate-info {
            display: flex;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .info-group {
            flex: 1;
            min-width: 180px;
            margin-bottom: 15px;
        }

        .info-label {
            font-size: 13px;
            color: #666;
            margin-bottom: 5px;
        }

        .info-value {
            font-size: 16px;
            font-weight: 600;
            color: #333;
        }

        .score-badge {
            display: inline-block;
            padding: 5px 12px;
            background-color: #e74c3c;
            color: white;
            font-weight: 600;
            border-radius: 20px;
            margin-left: 10px;
            font-size: 14px;
        }

        .certificate-actions {
            display: flex;
            justify-content: flex-end;
        }

        .btn-certificate {
            padding: 8px 18px;
            border-radius: 8px;
            background-color: #e74c3c;
            color: white;
            border: none;
            font-weight: 600;
            transition: all 0.2s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

        .btn-certificate i {
            margin-right: 8px;
        }

        .btn-certificate:hover {
            background-color: #c0392b;
            transform: translateY(-2px);
            color: white;
        }

        .empty-state {
            background: white;
            border-radius: 12px;
            padding: 40px;
            text-align: center;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }

        .empty-state i {
            font-size: 48px;
            color: #e74c3c;
            margin-bottom: 15px;
        }

        .empty-state h2 {
            font-size: 24px;
            color: #333;
            margin-bottom: 15px;
        }

        .empty-state p {
            font-size: 16px;
            color: #666;
            margin-bottom: 25px;
        }

        .btn-primary {
            background-color: #e74c3c;
            border-color: #e74c3c;
        }

        .btn-primary:hover {
            background-color: #c0392b;
            border-color: #c0392b;
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <!-- Sidebar -->
        <div class="sidebar">
            <div class="logo">
                <img src="~/images/student1.png" alt="School Logo">
                <h2>SCRED</h2>
                <p>Student Portal</p>
            </div>
            
            <a href="/Dashboard/StudentDashboard" class="sidebar-link">
                <i class="fas fa-th-large"></i> Dashboard
            </a>
            
            <a href="/Dashboard/StudentProfile" class="sidebar-link">
                <i class="fas fa-user"></i> Profile
            </a>
            
            <a href="/ProgrammingTest/StudentTests" class="sidebar-link">
                <i class="fas fa-code"></i> Programming Tests
            </a>
            
            <a href="/ProgrammingTest/Certificates" class="sidebar-link active">
                <i class="fas fa-award"></i> Certificates
            </a>
            
            <a href="/Home/Login" class="sidebar-link">
                <i class="fas fa-sign-out-alt"></i> Log Out
            </a>
        </div>
        
        <!-- Main Content -->
        <div class="content">
            <div class="page-header">
                <h1><i class="fas fa-award"></i> My Programming Certificates</h1>
                
                <a href="/ProgrammingTest/AvailableTests" class="btn btn-outline-primary">
                    <i class="fas fa-code"></i> Take New Test
                </a>
            </div>
            
            @if (Model == null || !Model.Any())
            {
                <div class="empty-state animate__animated animate__fadeIn">
                    <i class="fas fa-certificate"></i>
                    <h2>No Certificates Yet</h2>
                    <p>You haven't earned any certificates yet. Complete programming tests to earn certificates!</p>
                    <a href="/ProgrammingTest/AvailableTests" class="btn btn-primary btn-lg">
                        <i class="fas fa-code"></i> Go to Available Tests
                    </a>
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var certificate in Model)
                    {
                        <div class="col-md-6 mb-4">
                            <div class="certificate-card animate__animated animate__fadeIn">
                                <div class="certificate-header">
                                    <h3 class="certificate-title">
                                        <i class="fas fa-certificate"></i>
                                        @certificate.TestName
                                        <span class="score-badge">@certificate.Score%</span>
                                    </h3>
                                </div>
                                <div class="certificate-body">
                                    <div class="certificate-info">
                                        <div class="info-group">
                                            <div class="info-label">Programming Language</div>
                                            <div class="info-value">
                                                <i class="@GetLanguageIcon(certificate.ProgrammingLanguage)"></i> 
                                                @certificate.ProgrammingLanguage
                                            </div>
                                        </div>
                                        <div class="info-group">
                                            <div class="info-label">Grade Level</div>
                                            <div class="info-value">
                                                <i class="fas fa-graduation-cap"></i> 
                                                Level @certificate.GradeLevel
                                            </div>
                                        </div>
                                        <div class="info-group">
                                            <div class="info-label">Issue Date</div>
                                            <div class="info-value">
                                                <i class="far fa-calendar-alt"></i>
                                                @certificate.IssueDate.ToString("MMMM dd, yyyy")
                                            </div>
                                        </div>
                                    </div>
                                    <div class="certificate-actions">
                                        <a href="@Url.Action("ViewCertificate", "ProgrammingTest", new { id = certificate.CertificateId })" 
                                        target="_blank" class="btn-certificate">
                                            <i class="fas fa-award"></i> View Certificate
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function() {
            // Add staggered animation effect for multiple cards
            $(".certificate-card").each(function(index) {
                $(this).css("animation-delay", (index * 0.1) + "s");
            });
        });
    </script>
</body>
</html>

@functions {
    private string GetLanguageIcon(string language)
    {
        switch (language?.ToLower())
        {
            case "visual basic":
                return "fab fa-microsoft";
            case "html/css":
                return "fab fa-html5";
            case "python":
                return "fab fa-python";
            case "javascript":
                return "fab fa-js";
            case "php":
                return "fab fa-php";
            case "c":
                return "fas fa-code";
            case "c#":
                return "fab fa-microsoft";
            default:
                return "fas fa-code";
        }
    }
} 