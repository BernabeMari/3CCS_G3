        /* Custom animations for each score level - simplified approach */
        .student-pulse-platinum {
            animation: pulseBackgroundPlatinum 3s infinite !important;
            -webkit-animation: pulseBackgroundPlatinum 3s infinite !important;
            position: relative;
            border-left: 4px solid #00aaff !important;
        }
        
        .student-pulse-gold {
            animation: pulseBackgroundGold 3s infinite !important;
            -webkit-animation: pulseBackgroundGold 3s infinite !important;
            position: relative;
            border-left: 4px solid #ffd700 !important;
        }
        
        .student-pulse-silver {
            animation: pulseBackgroundSilver 3s infinite !important;
            -webkit-animation: pulseBackgroundSilver 3s infinite !important;
            position: relative;
            border-left: 4px solid #c0c0c0 !important;
        }
        
        .student-pulse-bronze {
            animation: pulseBackgroundBronze 3s infinite !important;
            -webkit-animation: pulseBackgroundBronze 3s infinite !important;
            position: relative;
            border-left: 4px solid #cd7f32 !important;
        }
        
        .student-pulse-rising {
            animation: pulseBackgroundRising 3s infinite !important;
            -webkit-animation: pulseBackgroundRising 3s infinite !important;
            position: relative;
            border-left: 4px solid #00ff00 !important;
        }
        
        .student-pulse-needs {
            animation: pulseBackgroundNeeds 3s infinite !important;
            -webkit-animation: pulseBackgroundNeeds 3s infinite !important;
            position: relative;
            border-left: 4px solid #ff0000 !important;
        }
        
        @@keyframes pulseBackgroundPlatinum {
            0% { box-shadow: 0 3px 8px rgba(0,150,255,0.3); border-color: rgba(0,150,255,0.7); }
            50% { box-shadow: 0 5px 15px rgba(0,150,255,0.7); border-color: rgba(0,150,255,1); background-color: rgba(0,150,255,0.15); }
            100% { box-shadow: 0 3px 8px rgba(0,150,255,0.3); border-color: rgba(0,150,255,0.7); }
        }
        
        @@keyframes pulseBackgroundGold {
            0% { box-shadow: 0 3px 8px rgba(255,215,0,0.3); border-color: rgba(255,215,0,0.7); }
            50% { box-shadow: 0 5px 15px rgba(255,215,0,0.7); border-color: rgba(255,215,0,1); background-color: rgba(255,215,0,0.15); }
            100% { box-shadow: 0 3px 8px rgba(255,215,0,0.3); border-color: rgba(255,215,0,0.7); }
        }
        
        @@keyframes pulseBackgroundSilver {
            0% { box-shadow: 0 3px 8px rgba(192,192,192,0.3); border-color: rgba(192,192,192,0.7); }
            50% { box-shadow: 0 5px 15px rgba(192,192,192,0.7); border-color: rgba(192,192,192,1); background-color: rgba(192,192,192,0.15); }
            100% { box-shadow: 0 3px 8px rgba(192,192,192,0.3); border-color: rgba(192,192,192,0.7); }
        }
        
        @@keyframes pulseBackgroundBronze {
            0% { box-shadow: 0 3px 8px rgba(205,127,50,0.3); border-color: rgba(205,127,50,0.7); }
            50% { box-shadow: 0 5px 15px rgba(205,127,50,0.7); border-color: rgba(205,127,50,1); background-color: rgba(205,127,50,0.15); }
            100% { box-shadow: 0 3px 8px rgba(205,127,50,0.3); border-color: rgba(205,127,50,0.7); }
        }
        
        @@keyframes pulseBackgroundRising {
            0% { box-shadow: 0 3px 8px rgba(0,255,0,0.3); border-color: rgba(0,255,0,0.7); }
            50% { box-shadow: 0 5px 15px rgba(0,255,0,0.7); border-color: rgba(0,255,0,1); background-color: rgba(0,255,0,0.15); }
            100% { box-shadow: 0 3px 8px rgba(0,255,0,0.3); border-color: rgba(0,255,0,0.7); }
        }
        
        @@keyframes pulseBackgroundNeeds {
            0% { box-shadow: 0 3px 8px rgba(255,0,0,0.3); border-color: rgba(255,0,0,0.7); }
            50% { box-shadow: 0 5px 15px rgba(255,0,0,0.7); border-color: rgba(255,0,0,1); background-color: rgba(255,0,0,0.15); }
            100% { box-shadow: 0 3px 8px rgba(255,0,0,0.3); border-color: rgba(255,0,0,0.7); }
        }

